generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  password           String
  name               String
  avatar             String?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  companyId          String?
  roleId             String?
  areaId             String?
  comments           Comment[]
  ownedCompany       Company?         @relation("CompanyOwner")
  employeeMeetings   Meeting[]        @relation("EmployeeMeetings")
  technicianMeetings Meeting[]        @relation("TechnicianMeetings")
  notifications      Notification[]
  activities         TicketActivity[]
  assignedTickets    Ticket[]         @relation("TicketAssignee")
  createdTickets     Ticket[]         @relation("TicketCreator")
  area               Area?            @relation(fields: [areaId], references: [id])
  company            Company?         @relation(fields: [companyId], references: [id])
  role               Role?            @relation(fields: [roleId], references: [id])

  @@index([areaId])
  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id])
  users       User[]
  permissions Permission[] @relation("RolePermissions")

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String
  createdAt   DateTime @default(now())
  roles       Role[]   @relation("RolePermissions")

  @@map("permissions")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String   @unique
  information String?
  logo        String?
  areas       Area[]
  owner       User     @relation("CompanyOwner", fields: [ownerId], references: [id])
  roles       Role[]
  tickets     Ticket[]
  members     User[]

  @@map("companies")
}

model Area {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tickets     Ticket[]
  users       User[]

  @@map("areas")
}

model Ticket {
  id                  String           @id @default(uuid())
  title               String
  description         String
  status              TicketStatus     @default(OPEN)
  priority            TicketPriority   @default(MEDIUM)
  category            String           @default("General")
  attachments         String[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  companyId           String
  areaId              String?
  createdById         String
  assignedToId        String?
  aiReasoning         String?
  aiSentiment         String?
  aiSuggestedArea     String?
  aiSuggestedPriority String?
  aiSummary           String?
  aiConfidence        Float?
  aiEstimatedTime     Int?
  resolvedAt          DateTime?
  comments            Comment[]
  meetings            Meeting[]
  activities          TicketActivity[]
  area                Area?            @relation(fields: [areaId], references: [id])
  assignedTo          User?            @relation("TicketAssignee", fields: [assignedToId], references: [id])
  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy           User             @relation("TicketCreator", fields: [createdById], references: [id])

  @@map("tickets")
}

model TicketActivity {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([userId])
  @@map("ticket_activities")
}

model Meeting {
  id               String        @id @default(uuid())
  title            String
  description      String?
  scheduledAt      DateTime
  duration         Int           @default(60)
  type             String
  status           MeetingStatus @default(PROPOSED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ticketId         String
  technicianId     String
  employeeId       String
  lastProposedById String?
  meetingLink      String?
  employee         User          @relation("EmployeeMeetings", fields: [employeeId], references: [id])
  technician       User          @relation("TechnicianMeetings", fields: [technicianId], references: [id])
  ticket           Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("meetings")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  link      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  ticketId  String
  userId    String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

enum MeetingStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum UserRole {
  EMPRESA
  EMPLEADO
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
